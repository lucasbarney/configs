    "@lucasbarney/prettier-configs": "*",
    "@types/node": "^25.6.0",
    "commitizen": "^4.3.1",
    "husky": "^9.1.7",
    "inquirer": "9",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
