{
  "compilerOptions": {
    "module": "nodenext",
    "target": "esnext",
    "rootDir": "./",
    "allowJs": true,
    "checkJs": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "exclude": ["node_modules/**/*", "index.js"],
  "include": ["*.ts", "*.mts"]
}
