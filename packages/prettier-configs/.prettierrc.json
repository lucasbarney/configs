{
  "semi": true,
  "tabWidth": 2,
  "printWidth": 80,
  "useTabs": false,

  "singleQuote": true,
  "trailingComma": "all",

  "bracketSpacing": true,
  "bracketSameLine": true,

  "arrowParens": "always",
  "quoteProps": "as-needed",

  "jsxSingleQuote": true,
  "singleAttributePerLine": false,

  "insertPragma": false,
  "requirePragma": false,
  "checkIgnorePragma": true,

  "endOfLine": "lf"
}
